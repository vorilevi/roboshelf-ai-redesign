<!--
  ROBOSHELF AI — Manipulációs Sandbox Scene v1
  MuJoCo MJCF

  Felépítés:
    - G1 robot (g1_29dof_with_hand.xml include) — rögzített test, csak jobb kar mozog
    - Padló + falak
    - Storage asztal (y=3.2, magasság 0.815m) — robot előtt
    - Gondola A (y=1.5) — 4 polcszinttel, robot mögött
    - 1 db stock termék (piros doboz) az asztalon — ezt kell a polcra tenni

  Robot pozíció: x=0, y=2.2 (asztal és polc között)
  Jobb kéz body neve: right_hand_palm_link
  Jobb kar aktuátorok (ctrl index 29-42):
    29: right_shoulder_pitch_joint
    30: right_shoulder_roll_joint
    31: right_shoulder_yaw_joint
    32: right_elbow_joint
    33: right_wrist_roll_joint
    34: right_wrist_pitch_joint
    35: right_wrist_yaw_joint
    36: right_hand_thumb_0_joint
    37: right_hand_thumb_1_joint
    38: right_hand_thumb_2_joint
    39: right_hand_index_0_joint
    40: right_hand_index_1_joint
    41: right_hand_middle_0_joint
    42: right_hand_middle_1_joint

  Polcszintek (gondola_A, y=1.5):
    b1: z=0.10  (alsó)
    b2: z=0.40
    b3: z=0.70
    b4: z=1.00  (felső)
  Target pozíció (b2, középső): x=-0.0, y=1.55, z=0.467
-->
<mujoco model="roboshelf_manip_sandbox_v1">

  <compiler angle="radian" autolimits="true"
            meshdir="../../../unitree_rl_gym/resources/robots/g1_description/meshes"/>

  <!-- timestep=0.002 → 500 Hz, implicitfast integrátor + alacsony kp = stabil -->
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    <global azimuth="180" elevation="-25" offwidth="1920" offheight="1080"/>
    <quality shadowsize="2048"/>
    <map znear="0.01" zfar="20"/>
  </visual>

  <default>
    <default class="product_box">
      <geom friction="0.8 0.01 0.001" condim="4" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </default>
    <!-- Jobb kar joint default: damping + armature a numerikus stabilitáshoz -->
    <default class="arm_joint">
      <joint damping="2.0" armature="0.01"/>
    </default>
    <default class="wrist_joint">
      <joint damping="0.5" armature="0.005"/>
    </default>
    <default class="finger_joint">
      <joint damping="0.1" armature="0.001"/>
    </default>
    <!-- Position actuator — kp a max erőhöz igazítva (actuatorfrcrange alapján) -->
    <default class="arm_motor">
      <position kp="20" forcerange="-25 25"/>
    </default>
    <default class="wrist_motor">
      <position kp="5" forcerange="-5 5"/>
    </default>
    <default class="finger_motor">
      <position kp="2" forcerange="-2.45 2.45"/>
    </default>
  </default>

  <asset>
    <texture name="tex_floor" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.82 0.82 0.78" rgb2="0.78 0.78 0.74"/>
    <material name="mat_floor"  texture="tex_floor" texrepeat="6 6" reflectance="0.1"/>
    <material name="mat_shelf"  rgba="0.7 0.7 0.7 1" reflectance="0.3" shininess="0.5"/>
    <material name="mat_board"  rgba="0.88 0.86 0.82 1" reflectance="0.05"/>
    <material name="mat_wall"   rgba="0.95 0.94 0.92 1"/>
    <material name="mat_red"    rgba="0.85 0.15 0.15 1"/>
    <material name="mat_green"  rgba="0.15 0.70 0.25 1"/>

    <!-- G1 mesh-ek (g1_29dof_with_hand.xml-ből) -->
    <mesh name="pelvis"                   file="pelvis.STL"/>
    <mesh name="pelvis_contour_link"      file="pelvis_contour_link.STL"/>
    <mesh name="torso_link"               file="torso_link.STL"/>
    <mesh name="left_shoulder_pitch_link" file="left_shoulder_pitch_link.STL"/>
    <mesh name="left_shoulder_roll_link"  file="left_shoulder_roll_link.STL"/>
    <mesh name="left_shoulder_yaw_link"   file="left_shoulder_yaw_link.STL"/>
    <mesh name="left_elbow_link"          file="left_elbow_link.STL"/>
    <mesh name="left_wrist_roll_link"     file="left_wrist_roll_link.STL"/>
    <mesh name="left_wrist_pitch_link"    file="left_wrist_pitch_link.STL"/>
    <mesh name="left_hand_palm_link"      file="left_hand_palm_link.STL"/>
    <mesh name="right_shoulder_pitch_link" file="right_shoulder_pitch_link.STL"/>
    <mesh name="right_shoulder_roll_link"  file="right_shoulder_roll_link.STL"/>
    <mesh name="right_shoulder_yaw_link"   file="right_shoulder_yaw_link.STL"/>
    <mesh name="right_elbow_link"          file="right_elbow_link.STL"/>
    <mesh name="right_wrist_roll_link"     file="right_wrist_roll_link.STL"/>
    <mesh name="right_wrist_pitch_link"    file="right_wrist_pitch_link.STL"/>
    <mesh name="right_hand_palm_link"      file="right_hand_palm_link.STL"/>
    <mesh name="right_hand_thumb_0_link"   file="right_hand_thumb_0_link.STL"/>
    <mesh name="right_hand_thumb_1_link"   file="right_hand_thumb_1_link.STL"/>
    <mesh name="right_hand_thumb_2_link"   file="right_hand_thumb_2_link.STL"/>
    <mesh name="right_hand_index_0_link"   file="right_hand_index_0_link.STL"/>
    <mesh name="right_hand_index_1_link"   file="right_hand_index_1_link.STL"/>
    <mesh name="right_hand_middle_0_link"  file="right_hand_middle_0_link.STL"/>
    <mesh name="right_hand_middle_1_link"  file="right_hand_middle_1_link.STL"/>
    <mesh name="left_hip_pitch_link"       file="left_hip_pitch_link.STL"/>
    <mesh name="left_hip_roll_link"        file="left_hip_roll_link.STL"/>
    <mesh name="left_hip_yaw_link"         file="left_hip_yaw_link.STL"/>
    <mesh name="left_knee_link"            file="left_knee_link.STL"/>
    <mesh name="left_ankle_pitch_link"     file="left_ankle_pitch_link.STL"/>
    <mesh name="left_ankle_roll_link"      file="left_ankle_roll_link.STL"/>
    <mesh name="right_hip_pitch_link"      file="right_hip_pitch_link.STL"/>
    <mesh name="right_hip_roll_link"       file="right_hip_roll_link.STL"/>
    <mesh name="right_hip_yaw_link"        file="right_hip_yaw_link.STL"/>
    <mesh name="right_knee_link"           file="right_knee_link.STL"/>
    <mesh name="right_ankle_pitch_link"    file="right_ankle_pitch_link.STL"/>
    <mesh name="right_ankle_roll_link"     file="right_ankle_roll_link.STL"/>
  </asset>

  <worldbody>

    <!-- Világítás -->
    <light name="ceil_1" pos="0 2.0 3.0" dir="0 0 -1" diffuse="0.9 0.9 0.9" castshadow="true" cutoff="60"/>
    <light name="ceil_2" pos="0 1.0 3.0" dir="0 0 -1" diffuse="0.7 0.7 0.7" castshadow="false" cutoff="60"/>

    <!-- Padló -->
    <geom name="floor" type="plane" size="4 4 0.01" material="mat_floor"/>

    <!-- ========== G1 ROBOT (rögzített alap) ========== -->
    <!-- A pelvis weld joint-tal rögzítve: x=0, y=2.2, z=0.793 (álló magasság) -->
    <body name="pelvis" pos="0 2.2 0.793">
      <!-- NINCS freejoint — a test rögzített -->
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.2 0.2 0.2 1" mesh="pelvis"/>
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="pelvis_contour_link"/>
      <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="pelvis_contour_link" mass="5.0"/>
      <site name="imu_in_pelvis" size="0.01" pos="0.04525 0 -0.08339"/>

      <body name="torso_link" pos="0 0 0.019">
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="torso_link"/>
        <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="torso_link" mass="10.0"/>
        <site name="imu_in_torso" size="0.01" pos="-0.03959 -0.00224 0.13792"/>

        <!-- BAL KAR (passzív — egyszerűsített box, nem animált) -->
        <body name="left_arm_dummy" pos="0.0 0.1 0.3">
          <geom type="box" size="0.05 0.25 0.04" rgba="0.3 0.3 0.3 0.5" mass="3.0" contype="0" conaffinity="0"/>
        </body>

        <!-- JOBB KAR — aktív, position actuator-okkal -->
        <body name="right_shoulder_pitch_link" pos="-0.0035 -0.1205 0.2595">
          <joint name="right_shoulder_pitch_joint" class="arm_joint" axis="0 1 0" range="-3.0892 2.6704"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_pitch_link"/>
          <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_pitch_link" mass="1.5"/>

          <body name="right_shoulder_roll_link" pos="0 -0.0415 0">
            <joint name="right_shoulder_roll_joint" class="arm_joint" axis="1 0 0" range="-2.2515 1.5882"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_roll_link"/>
            <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_roll_link" mass="1.5"/>

            <body name="right_shoulder_yaw_link" pos="0 -0.1233 0">
              <joint name="right_shoulder_yaw_joint" class="arm_joint" axis="0 0 1" range="-2.618 2.618"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_yaw_link"/>
              <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_shoulder_yaw_link" mass="1.5"/>

              <body name="right_elbow_link" pos="0 0 -0.1838">
                <joint name="right_elbow_joint" class="arm_joint" axis="0 1 0" range="-1.0472 2.0944"/>
                <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_elbow_link"/>
                <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_elbow_link" mass="1.0"/>

                <body name="right_wrist_roll_link" pos="0 0 -0.18">
                  <joint name="right_wrist_roll_joint" class="wrist_joint" axis="1 0 0" range="-1.97222 1.97222"/>
                  <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_wrist_roll_link"/>
                  <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_wrist_roll_link" mass="0.5"/>

                  <body name="right_wrist_pitch_link" pos="0 0 -0.0596">
                    <joint name="right_wrist_pitch_joint" class="wrist_joint" axis="0 1 0" range="-1.61443 1.61443"/>
                    <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_wrist_pitch_link"/>
                    <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_wrist_pitch_link" mass="0.3"/>

                    <body name="right_hand_palm_link" pos="0 0 -0.07">
                      <joint name="right_wrist_yaw_joint" class="wrist_joint" axis="0 0 1" range="-1.61443 1.61443"/>
                      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="right_hand_palm_link"/>
                      <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="right_hand_palm_link" mass="0.5"/>
                      <site name="right_hand_site" size="0.02" pos="0 0 -0.07" rgba="0 1 0 0.5"/>

                      <!-- Ujjak: thumb -->
                      <body name="right_hand_thumb_0_link" pos="0.0175 -0.012 -0.0446">
                        <joint name="right_hand_thumb_0_joint" class="finger_joint" axis="0 1 0" range="-1.0472 1.0472"/>
                        <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_thumb_0_link" mass="0.05"/>
                        <body name="right_hand_thumb_1_link" pos="0 0 -0.0381">
                          <joint name="right_hand_thumb_1_joint" class="finger_joint" axis="0 0 1" range="-1.0472 0.724312"/>
                          <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_thumb_1_link" mass="0.03"/>
                          <body name="right_hand_thumb_2_link" pos="0 0 -0.025">
                            <joint name="right_hand_thumb_2_joint" class="finger_joint" axis="0 0 1" range="-1.74533 0"/>
                            <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_thumb_2_link" mass="0.02"/>
                          </body>
                        </body>
                      </body>

                      <!-- Ujjak: index -->
                      <body name="right_hand_index_0_link" pos="-0.0075 -0.013 -0.1055">
                        <joint name="right_hand_index_0_joint" class="finger_joint" axis="0 0 1" range="0 1.5708"/>
                        <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_index_0_link" mass="0.04"/>
                        <body name="right_hand_index_1_link" pos="0 0 -0.028">
                          <joint name="right_hand_index_1_joint" class="finger_joint" axis="0 0 1" range="0 1.74533"/>
                          <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_index_1_link" mass="0.02"/>
                        </body>
                      </body>

                      <!-- Ujjak: middle -->
                      <body name="right_hand_middle_0_link" pos="0.0075 -0.013 -0.1055">
                        <joint name="right_hand_middle_0_joint" class="finger_joint" axis="0 0 1" range="0 1.5708"/>
                        <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_middle_0_link" mass="0.04"/>
                        <body name="right_hand_middle_1_link" pos="0 0 -0.028">
                          <joint name="right_hand_middle_1_joint" class="finger_joint" axis="0 0 1" range="0 1.74533"/>
                          <geom type="mesh" rgba="0.6 0.6 0.6 1" mesh="right_hand_middle_1_link" mass="0.02"/>
                        </body>
                      </body>

                    </body><!-- right_hand_palm_link -->
                  </body><!-- right_wrist_pitch_link -->
                </body><!-- right_wrist_roll_link -->
              </body><!-- right_elbow_link -->
            </body><!-- right_shoulder_yaw_link -->
          </body><!-- right_shoulder_roll_link -->
        </body><!-- right_shoulder_pitch_link -->

      </body><!-- torso_link -->
    </body><!-- pelvis -->

    <!-- ========== STORAGE ASZTAL (robot előtt, y=3.2) ========== -->
    <body name="storage" pos="0 3.2 0">
      <geom name="st_legs" type="box" size="0.6 0.30 0.40" pos="0 0 0.40" rgba="0.50 0.45 0.35 1"/>
      <geom name="st_top"  type="box" size="0.6 0.30 0.015" pos="0 0 0.815" rgba="0.60 0.55 0.45 1"/>
    </body>

    <!-- ========== GONDOLA A (robot mögött, y=1.2) ========== -->
    <body name="gondola_A" pos="0 1.2 0">
      <geom name="gA_sL" type="box" size="0.02 0.40 0.60" pos="-0.35 0 0.60" material="mat_shelf"/>
      <geom name="gA_sR" type="box" size="0.02 0.40 0.60" pos="0.35 0 0.60"  material="mat_shelf"/>
      <geom name="gA_bk" type="box" size="0.35 0.01 0.60" pos="0 -0.20 0.60" material="mat_shelf"/>
      <geom name="gA_b1" type="box" size="0.33 0.18 0.012" pos="0 0 0.10" material="mat_board"/>
      <geom name="gA_b2" type="box" size="0.33 0.18 0.012" pos="0 0 0.40" material="mat_board"/>
      <geom name="gA_b3" type="box" size="0.33 0.18 0.012" pos="0 0 0.70" material="mat_board"/>
      <geom name="gA_b4" type="box" size="0.33 0.18 0.012" pos="0 0 1.00" material="mat_board"/>
    </body>

    <!-- ========== STOCK TERMÉK (piros doboz az asztalon) ========== -->
    <!-- Asztalfelszín: z=0.815, doboz félmagasság: 0.055 → z=0.870 -->
    <body name="stock_1" pos="-0.15 3.2 0.870">
      <freejoint/>
      <geom type="box" size="0.06 0.04 0.055" class="product_box" material="mat_red" mass="0.35"/>
      <site name="stock_1_site" size="0.01" rgba="1 0 0 0.8"/>
    </body>

    <!-- ========== TARGET POZÍCIÓ (2. polcszint, középső) ========== -->
    <!-- Polc b2: z=0.40 + 0.012 + 0.055 = 0.467 -->
    <site name="target_shelf" type="box" size="0.065 0.045 0.002"
          pos="0 1.25 0.415" rgba="0 1 0 0.4"/>

  </worldbody>

  <!-- ========== AKTUÁTOROK — csak jobb kar (position control) ========== -->
  <actuator>
    <position name="right_shoulder_pitch" joint="right_shoulder_pitch_joint" class="arm_motor"/>
    <position name="right_shoulder_roll"  joint="right_shoulder_roll_joint"  class="arm_motor"/>
    <position name="right_shoulder_yaw"   joint="right_shoulder_yaw_joint"   class="arm_motor"/>
    <position name="right_elbow"          joint="right_elbow_joint"          class="arm_motor"/>
    <position name="right_wrist_roll"     joint="right_wrist_roll_joint"     class="wrist_motor"/>
    <position name="right_wrist_pitch"    joint="right_wrist_pitch_joint"    class="wrist_motor"/>
    <position name="right_wrist_yaw"      joint="right_wrist_yaw_joint"      class="wrist_motor"/>
    <position name="right_thumb_0"        joint="right_hand_thumb_0_joint"   class="finger_motor"/>
    <position name="right_thumb_1"        joint="right_hand_thumb_1_joint"   class="finger_motor"/>
    <position name="right_thumb_2"        joint="right_hand_thumb_2_joint"   class="finger_motor"/>
    <position name="right_index_0"        joint="right_hand_index_0_joint"   class="finger_motor"/>
    <position name="right_index_1"        joint="right_hand_index_1_joint"   class="finger_motor"/>
    <position name="right_middle_0"       joint="right_hand_middle_0_joint"  class="finger_motor"/>
    <position name="right_middle_1"       joint="right_hand_middle_1_joint"  class="finger_motor"/>
  </actuator>

  <!-- ========== SZENZOR ========== -->
  <sensor>
    <framepos  name="s_stock_1"      objtype="body" objname="stock_1"/>
    <framepos  name="s_right_hand"   objtype="site" objname="right_hand_site"/>
    <framepos  name="s_target"       objtype="site" objname="target_shelf"/>
    <touch     name="touch_thumb"    site="right_hand_site"/>
  </sensor>

</mujoco>
